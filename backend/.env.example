PORT=3001

# Google Service Account (JSON key file path)
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/service-account.json

# 아래 ID는 선택 — 앱에서 사내/외부인 시트 각각 등록 가능. 배치 메일용 서버 기본값(사내용) 설정 권장
GOOGLE_SPREADSHEET_ID=
# OpenAI — GPT 음성 파싱 (없으면 mock 모드)
OPENAI_API_KEY=sk-...

# 서명 이미지 저장용 Google Drive 폴더 ID (폴더를 서비스 계정에 편집자로 공유)
# 없으면 시트에 "서명완료" 텍스트만 저장됩니다
GOOGLE_DRIVE_SIGNATURE_FOLDER_ID=

# SMTP (반납 안내 메일)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=재고관리시스템 <your@gmail.com>

# 배치 스케줄 (cron 표현식, 기본: 매일 09:00)
REMINDER_CRON=0 9 * * *
